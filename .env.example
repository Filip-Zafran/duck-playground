# Server
NODE_ENV=development
PORT=3001
HOST=localhost

# Database (PostgreSQL - free tier on Railway.app or Render.com)
DATABASE_URL=postgresql://user:password@localhost:5432/duck_playground
DB_HOST=localhost
DB_PORT=5432
DB_USER=duck_user
DB_PASSWORD=your_password
DB_NAME=duck_playground

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Admin Password (for initial setup)
ADMIN_PASSWORD=change_me_in_production

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:4321

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Image Generation
IMAGE_QUALITY=80
IMAGE_WIDTH=1200
IMAGE_HEIGHT=630
