    "pg": "^8.11.0",
    "sharp": "^0.35.1",
    "socket.io": "^4.7.0",
    "svelte": "^5.56.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@astrojs/svelte": "^7.0.0",
